---
import Layout from "../layouts/Layout.astro";
import SectionContainer from "../components/SectionContainer.astro";
import FinalCTA from "../sections/FinalCTA.astro";
import { Image } from "astro:assets";
import accidenteTrabajo from "../assets/images/accidente-de-trabajo.jpg";
import WhatsApp from "../icons/WhatsApp.astro";
import Check from "../icons/Check.astro";
import ArrowRight from "../icons/ArrowRight.astro";
import Plus from "../icons/Plus.astro";
import MedicineSyrup from "../icons/MedicineSyrup.astro";
import Scale from "../icons/Scale.astro";
import BuildingHospital from "../icons/BuildingHospital.astro";
import HeartBroken from "../icons/HeartBroken.astro";
import Brain from "../icons/Brain.astro";
import PigMoney from "../icons/PigMoney.astro";

const title = "Accidentes de Trabajo | Estudio Enzetti";
const description =
  "Sufriste un accidente laboral? Reclamamos la indemnización que merecés. Abogados especializados en accidentes de trabajo en Buenos Aires. Consulta gratuita.";

const benefits = [
  "Evaluamos tu caso sin costo y sin compromiso",
  "Sin honorarios hasta que cobres tu indemnización",
  "Más de 30 años de experiencia en derecho laboral",
  "Seguimiento médico y legal durante todo el proceso",
  "Atención personalizada y cercana",
];

const faqItems = [
  {
    question: "¿Qué es un accidente de trabajo?",
    answer:
      "Es todo hecho súbito y violento que ocurre por el hecho o en ocasión del trabajo, o en el trayecto entre el domicilio del trabajador y el lugar de trabajo, siempre que el damnificado no hubiere interrumpido o alterado dicho trayecto.",
  },
  {
    question: "¿Quién me cubre si sufrí un accidente de trabajo?",
    answer:
      "Tu empleador está obligado por ley (Ley 24.557) a contratar un seguro con una ART (Aseguradora de Riesgos del Trabajo). La ART es la entidad responsable de cubrir las prestaciones económicas y médicas por el accidente.",
  },
  {
    question: "¿Cuánto tiempo tengo para reclamar?",
    answer:
      "El plazo de prescripción para acciones derivadas de la LRT es de 2 años desde la fecha del accidente o desde que se determinó la incapacidad. Sin embargo, es recomendable consultar a un abogado lo antes posible para resguardar tus derechos.",
  },
  {
    question: "¿Puedo demandar tanto a la ART como a mi empleador?",
    answer:
      "Sí. Podés reclamar a la ART por el régimen especial de la Ley de Riesgos del Trabajo, y en paralelo iniciar una demanda civil contra tu empleador si el accidente fue consecuencia de su negligencia o falta de medidas de seguridad.",
  },
  {
    question: "¿Cuánto tiempo tarda el proceso?",
    answer:
      "El tiempo varía según la complejidad del caso. Muchos casos se resuelven por vía extrajudicial en pocos meses. Los juicios pueden tardar entre 1 y 3 años dependiendo de la jurisdicción y la complejidad de la causa.",
  },
];

const claimItems = [
  {
    title: "Incapacidad Laboral Temporaria (ILT)",
    description: "Cubre el periodo en que no podés trabajar mientras te recuperás del accidente.",
    icon: MedicineSyrup,
  },
  {
    title: "Incapacidad Laboral Permanente (ILP)",
    description: "Indemnización por las secuelas permanentes que afectan tu capacidad de trabajo.",
    icon: Scale,
  },
  {
    title: "Gran Invalidez",
    description: "Para los casos donde necesitás la asistencia permanente de otra persona para realizar actos elementales.",
    icon: BuildingHospital,
  },
  {
    title: "Daño Moral",
    description: "Reparación por el sufrimiento psicológico y emocional provocado por el accidente y la negligencia.",
    icon: HeartBroken,
  },
  {
    title: "Daño Psicológico",
    description: "Indemnización por las consecuencias psíquicas derivadas del accidente de trabajo.",
    icon: Brain,
  },
  {
    title: "Lucro Cesante",
    description: "Compensación económica por los ingresos que dejaste de percibir a causa del accidente.",
    icon: PigMoney,
  },
];
---

<Layout title={title} description={description}>
  <main>
    {/* Hero Section */}
    <SectionContainer
      id="hero"
      class="relative overflow-hidden bg-gradient-to-b from-white to-gray-50"
      enableAnimation={false}
    >
      <div
        class="absolute inset-0 -z-10 h-full w-full bg-white bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:16px_16px]"
      >
        <div
          class="absolute inset-0 bg-white/40 [mask-image:radial-gradient(ellipse_at_center,transparent_20%,black)]"
        >
        </div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-24">
        {/* Breadcrumb */}
        <nav class="mb-8 text-sm text-gray-500 opacity-0 service-breadcrumb">
          <a href="/" class="hover:text-accent transition-colors">Inicio</a>
          <span class="mx-2">/</span>
          <span class="text-primary font-medium">Accidentes de Trabajo</span>
        </nav>

        <div class="grid lg:grid-cols-2 gap-16 items-center">
          {/* Left: Content */}
          <div class="space-y-8">
            <div>
              <span
                class="inline-block text-sm font-bold text-accent uppercase tracking-wider mb-4 opacity-0 translate-y-4 service-badge"
              >
                Área de Práctica
              </span>
              <h1
                class="text-5xl lg:text-6xl font-bold text-primary leading-tight mb-6 opacity-0 translate-y-4 service-title"
              >
                Accidentes de <span class="text-accent">Trabajo</span>
              </h1>
              <p
                class="text-xl text-gray-600 leading-relaxed opacity-0 translate-y-4 service-desc"
              >
                Reclamamos la indemnización que merecés tras lesiones sufridas
                en el ámbito laboral. Te asistimos en cada etapa del proceso, de
                manera gratuita hasta que cobres.
              </p>
            </div>

            <ul class="space-y-3 opacity-0 translate-y-4 service-benefits">
              {
                benefits.map((benefit) => (
                  <li class="flex items-start gap-3 text-gray-700">
                    <div class="w-5 h-5 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <Check class="w-3 h-3 text-accent" />
                    </div>
                    <span>{benefit}</span>
                  </li>
                ))
              }
            </ul>

            <div
              class="flex flex-col sm:flex-row gap-4 opacity-0 translate-y-4 service-btns"
            >
              <a
                href="https://wa.me/5491143711602"
                target="_blank"
                rel="noopener noreferrer"
                class="w-full sm:w-auto"
              >
                <button
                  class="w-full sm:w-auto bg-green-500 hover:bg-green-600 text-white font-bold text-lg px-8 py-4 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:scale-105 flex items-center justify-center gap-3 cursor-pointer whitespace-nowrap"
                >
                  <WhatsApp class="w-6 h-6" />
                  Consulta sin cargo
                </button>
              </a>
              <a href="/#servicios" class="w-full sm:w-auto">
                <button
                  class="w-full sm:w-auto border-2 border-primary text-primary hover:bg-primary hover:text-white font-bold text-lg px-8 py-4 rounded-xl transition-all duration-300 flex items-center justify-center gap-3 cursor-pointer whitespace-nowrap"
                >
                  Ver todos los servicios
                  <ArrowRight />
                </button>
              </a>
            </div>
          </div>

          {/* Right: Image */}
          <div class="relative opacity-0 scale-95 service-image">
            <div class="rounded-3xl overflow-hidden shadow-2xl">
              <Image
                src={accidenteTrabajo}
                alt="Accidente de trabajo - Estudio Enzetti"
                class="w-full h-full object-cover"
              />
            </div>
            <div
              class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-5 border border-gray-100"
            >
              <div class="text-3xl font-bold text-accent">30+</div>
              <div class="text-sm text-gray-600">Años de experiencia</div>
            </div>
            <div
              class="absolute -top-6 -right-6 bg-accent rounded-2xl shadow-xl p-5 text-white"
            >
              <div class="text-3xl font-bold">5.0 ★</div>
              <div class="text-sm opacity-90">Calificación Google</div>
            </div>
          </div>
        </div>
      </div>
    </SectionContainer>

    <script>
      import "../scripts/service-animations.js";
    </script>

    {/* What we claim section */}
    <SectionContainer id="que-reclamamos" class="bg-zinc-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <p class="accent-rule mb-5">¿Qué reclamamos?</p>
          <h3 class="text-4xl md:text-5xl font-bold text-primary mb-4">
            Tipos de indemnización
          </h3>
          <p class="text-lg text-zinc-500 leading-relaxed">
            Conocé todos los rubros que podemos reclamar en tu nombre
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {
            claimItems.map(({ title, description, icon: Icon }, index) => (
              <div class="relative bg-white border border-zinc-100 rounded-xl p-6 overflow-hidden group hover:-translate-y-0.5 hover:shadow-md hover:border-zinc-200 transition-all duration-300">
                <div class="absolute left-0 inset-y-0 w-[3px] bg-accent origin-bottom scale-y-0 group-hover:scale-y-100 transition-transform duration-300 rounded-r-full" />
                <span class="absolute top-4 right-5 font-serif text-3xl font-bold leading-none select-none text-zinc-100 group-hover:text-accent/20 transition-colors duration-300">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <div class="w-11 h-11 rounded-lg bg-accent/10 flex items-center justify-center text-accent mb-5 group-hover:bg-accent/15 transition-colors duration-300">
                  <Icon class="w-5 h-5" />
                </div>
                <h4 class="font-serif text-base font-bold text-primary mb-2 leading-snug pr-8 group-hover:text-accent transition-colors duration-300">
                  {title}
                </h4>
                <p class="text-sm text-zinc-500 leading-relaxed">{description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </SectionContainer>

    {/* FAQ Section */}
    <SectionContainer
      id="preguntas-frecuentes"
      class="bg-gradient-to-b from-gray-50 to-white"
    >
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2
            class="text-sm font-bold text-accent uppercase tracking-wider mb-3"
          >
            Preguntas Frecuentes
          </h2>
          <h3 class="text-4xl md:text-5xl font-bold text-primary mb-6">
            Dudas comunes
          </h3>
        </div>

        <div class="space-y-4">
          {
            faqItems.map((item, index) => (
              <details class="faq-item opacity-0 group bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                  <span class="font-semibold text-primary text-lg group-open:text-accent transition-colors duration-300">
                    {item.question}
                  </span>
                  <Plus class="ml-4 w-5 h-5 text-accent flex-shrink-0 transition-transform duration-300 group-open:rotate-45" />
                </summary>
                <div class="faq-content px-6 pb-6">
                  <p class="text-gray-600 leading-relaxed">{item.answer}</p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </SectionContainer>

    <SectionContainer id="final-cta" class="bg-white">
      <FinalCTA />
    </SectionContainer>
  </main>
</Layout>
