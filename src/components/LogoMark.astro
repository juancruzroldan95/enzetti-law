---
/**
 * Pure HTML/CSS replica of the Estudio Enzetti logo.
 * No image file — fully transparent background, works on any surface.
 *
 * Layout:
 *   [E]   [| text-block]
 *           ESTUDIO ENZETTI
 *           ABOGADOS
 *
 * The bar and text block are wrapped in a nested items-stretch container
 * so the bar auto-sizes to exactly the height of the two text lines.
 *
 * Props:
 *   size — "lg" (header) | "md" (footer/mobile) | "sm" (compact)
 */
interface Props {
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { size = "lg", class: className = "" } = Astro.props;

const sizes = {
  lg: {
    outerGap:    "gap-[6px]",
    eLetter:     "text-[32px]",
    innerGap:    "gap-[6px]",
    barWidth:    "w-[2.5px]",
    firm:        "text-[19px]",
    sub:         "text-[10.5px]",
    textGap:     "gap-[3px]",
    tracking:    "tracking-[0.075em]",
    subTracking: "tracking-[0.28em]",
  },
  md: {
    outerGap:    "gap-[5px]",
    eLetter:     "text-[28px]",
    innerGap:    "gap-[5px]",
    barWidth:    "w-[2px]",
    firm:        "text-[15px]",
    sub:         "text-[8.5px]",
    textGap:     "gap-[3px]",
    tracking:    "tracking-[0.075em]",
    subTracking: "tracking-[0.26em]",
  },
  sm: {
    outerGap:    "gap-[4px]",
    eLetter:     "text-[26px]",
    innerGap:    "gap-[4px]",
    barWidth:    "w-[2px]",
    firm:        "text-[12px]",
    sub:         "text-[7px]",
    textGap:     "gap-[2px]",
    tracking:    "tracking-[0.07em]",
    subTracking: "tracking-[0.24em]",
  },
} as const;

const s = sizes[size];
---

<div
  class={`inline-flex items-center select-none ${s.outerGap} ${className}`}
  aria-label="Estudio Enzetti Abogados"
  role="img"
>
  {/* "E" lettermark — centered with the inner group */}
  <span
    class={`font-sans font-medium leading-none text-primary ${s.eLetter}`}
    aria-hidden="true"
  >E</span>

  {/*
    Inner group: bar + text block, with items-stretch so the bar
    auto-sizes to exactly the height of the two text lines.
  */}
  <div
    class={`flex items-stretch ${s.innerGap}`}
    aria-hidden="true"
  >
    {/* Red vertical separator — stretches to match text block height */}
    <div class={`bg-accent rounded-sm flex-shrink-0 ${s.barWidth}`} />

    {/* Text block */}
    <div class={`flex flex-col ${s.textGap}`}>
      {/* Firm name: "ESTUDIO" regular + "ENZETTI" bold */}
      <div
        class={`font-sans leading-none text-primary whitespace-nowrap ${s.firm} ${s.tracking}`}
      >
        <span class="font-normal">ESTUDIO&nbsp;</span><span class="font-bold">ENZETTI</span>
      </div>

      {/* Tagline in accent red */}
      <div
        class={`font-sans font-semibold leading-none text-accent whitespace-nowrap ${s.sub} ${s.subTracking}`}
      >
        ABOGADOS
      </div>
    </div>
  </div>
</div>
