---
import LogoMark from "./LogoMark.astro";
import WhatsApp from "../icons/WhatsApp.astro";
import Menu from "../icons/Menu.astro";

const { pathname } = Astro.url;

const navItems = [
  { name: "Servicios", href: "#servicios" },
  { name: "Equipo", href: "#equipo" },
  { name: "Redes", href: "#redes" },
  { name: "Proceso", href: "#proceso" },
  { name: "Reseñas", href: "#resenas" },
  { name: "Nosotros", href: "/nosotros" },
  { name: "Contacto", href: "/contacto" },
];
---

<header
  id="site-header"
  class="bg-white/90 backdrop-blur-md sticky top-0 z-50 border-b border-zinc-100/80 transition-all duration-300"
>
  <div
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center h-16 md:h-[70px]"
  >
    <a href="/" aria-label="Estudio Enzetti — inicio">
      <LogoMark size="lg" />
    </a>

    <nav class="hidden lg:flex items-center space-x-1 lg:space-x-2">
      {
        navItems.map((item) => {
          const href =
            item.href.startsWith("#") && pathname !== "/"
              ? `/${item.href}`
              : item.href;
          return (
            <a
              href={href}
              class="relative px-3 py-2 text-primary/70 hover:text-primary text-sm font-medium tracking-wide transition-colors duration-200 group font-sans"
            >
              {item.name}
              <span class="absolute bottom-0 left-3 right-3 h-px bg-accent scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left" />
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://wa.me/5491143711602"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:block"
      >
        <button
          class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg font-semibold transition-all duration-300 hover:shadow-md hover:shadow-green-500/25 text-sm flex items-center gap-2 cursor-pointer font-sans"
        >
          <WhatsApp class="w-4 h-4" />
          Consulta Gratuita
        </button>
      </a>

      <button
        id="open-menu"
        class="lg:hidden text-primary/70 hover:text-primary p-2 cursor-pointer relative z-10 transition-colors"
        aria-label="Abrir menú"
      >
        <Menu />
      </button>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    window.addEventListener(
      "scroll",
      () => {
        header.classList.toggle("shadow-sm", window.scrollY > 16);
      },
      { passive: true },
    );
  }
</script>
