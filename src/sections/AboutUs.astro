---
import { Image } from "astro:assets";
import featureImage from "../assets/images/Gemini_Generated_Image_jrac26jrac26jrac.jpg";
import Scale from "../icons/Scale.astro";
import Users from "../icons/Users.astro";
import Award from "../icons/Award.astro";
import TrendingUp from "../icons/TrendingUp.astro";

const FEATURES = [
  {
    icon: Scale,
    title: "Experiencia Comprobada",
    description:
      "Más de 30 años ayudando a trabajadores a obtener sus derechos",
  },
  {
    icon: Users,
    title: "Equipo Interdisciplinario",
    description: "Abogados especializados y médicos legistas trabajando juntos",
  },
  {
    icon: Award,
    title: "Resultados Garantizados",
    description: "Miles de casos exitosos y clientes satisfechos",
  },
  {
    icon: TrendingUp,
    title: "Máxima Indemnización",
    description: "Nos comprometemos a obtener el mejor resultado posible",
  },
];
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
  <div class="grid lg:grid-cols-2 gap-16 items-center">
    {/* Left — Image with decorative frame */}
    <div class="relative">
      {/* Decorative border offset */}
      <div class="absolute -bottom-4 -right-4 w-full h-full rounded-2xl border-2 border-accent/15 rounded-2xl -z-10" />
      <div class="absolute -bottom-8 -right-8 w-full h-full rounded-2xl bg-stone-100 -z-20" />
      <Image
        src={featureImage}
        alt="Equipo Enzetti"
        class="w-full h-auto object-cover rounded-2xl shadow-xl shadow-primary/10 relative z-10"
      />
      {/* Year badge overlay */}
      <div class="absolute bottom-6 left-6 z-20 bg-primary/90 backdrop-blur-sm text-white px-5 py-3 rounded-xl shadow-lg">
        <div class="text-3xl font-bold leading-none" style="font-family: var(--font-serif);">1992</div>
        <div class="text-white/60 text-xs mt-0.5 font-sans tracking-wide">Desde siempre</div>
      </div>
    </div>

    {/* Right — Content */}
    <div class="space-y-8">
      <div>
        <div class="accent-rule mb-4">
          <span>Sobre Nosotros</span>
        </div>
        <h2 class="text-5xl md:text-6xl font-bold text-primary leading-tight mb-6">
          Defendiendo tus derechos desde 1992
        </h2>
      </div>

      <p class="text-base text-primary/60 leading-relaxed">
        En el <span class="font-semibold text-primary"
          >Estudio Jurídico Enzetti</span
        >, contamos con un equipo interdisciplinario de abogados especializados
        y médicos legistas con amplia experiencia en la gestión de reclamos por
        accidentes de trabajo, enfermedades profesionales y accidentes de
        tránsito.
      </p>

      <p class="text-base text-primary/60 leading-relaxed">
        En cada caso aplicamos una metodología clara y personalizada,
        asegurándonos de que recibas <span class="font-semibold text-primary"
          >el mejor servicio jurídico disponible</span
        >.
      </p>

      {/* Features Grid */}
      <div class="grid sm:grid-cols-2 gap-4 pt-4">
        {
          FEATURES.map((feature) => {
            const Icon = feature.icon;
            return (
              <div class="feature-card flex items-start gap-4 p-4 rounded-xl border border-stone-100 hover:border-accent/20 hover:bg-accent/3 transition-all duration-300 group">
                <div class="w-10 h-10 rounded-lg bg-accent/8 flex items-center justify-center text-accent flex-shrink-0 group-hover:bg-accent group-hover:text-white transition-all duration-300">
                  <Icon class="w-5 h-5" />
                </div>
                <div>
                  <h4 class="text-sm font-bold text-primary mb-1">{feature.title}</h4>
                  <p class="text-xs text-primary/50 leading-relaxed">{feature.description}</p>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</div>
