---
import PlayerPlay from "../icons/PlayerPlay.astro";
import { VIDEOS, muxThumbnail } from "../consts/videos";
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
  {/* Header */}
  <div class="text-center max-w-3xl mx-auto mb-16">
    <div class="accent-rule mb-4">
      <span>Nuestro Equipo</span>
    </div>
    <h2 class="text-5xl md:text-6xl font-bold text-primary mb-6">
      Conocé cómo trabajamos
    </h2>
    <p class="text-base text-primary/60 leading-relaxed">
      Nuestro equipo te cuenta el proceso y compromiso que tenemos con cada caso
    </p>
  </div>

  {/* Videos Grid - Instagram style */}
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
    {
      VIDEOS.map((video) => (
        <div class="relative group cursor-pointer video-card">
          {/* Video Container - Instagram format (9:16 ratio) */}
          <div class="relative aspect-[9/16] rounded-2xl overflow-hidden shadow-lg bg-gray-900">
            {/* Poster image — first frame via Mux Image API */}
            <img
              src={muxThumbnail(video.playbackId)}
              alt={video.title}
              class="video-poster w-full h-full object-cover"
              loading="lazy"
            />

            {/* Mux video element — playback-id injected on click */}
            <mux-video
              class="video-player w-full h-full object-cover absolute inset-0 hidden"
              data-playback-id={video.playbackId}
              poster={muxThumbnail(video.playbackId)}
              metadata-video-title={video.title}
              playsinline
              controls
              disablepictureinpicture
              disable-tracking
            />

            {/* Overlay — visible while poster is shown */}
            <div class="video-overlay absolute inset-0 transition-opacity duration-300">
              {/* Dark overlay */}
              <div class="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition-colors duration-300" />

              {/* Play button */}
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-16 h-16 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-xl text-accent text-2xl">
                  <PlayerPlay />
                </div>
              </div>

              {/* Duration badge */}
              <div class="absolute top-3 right-3 bg-black/70 backdrop-blur-sm text-white text-xs font-semibold px-2 py-1 rounded">
                {video.duration}
              </div>

              {/* Info overlay */}
              <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/90 to-transparent">
                <p class="text-white font-bold text-sm mb-1">{video.title}</p>
                <p class="text-white/80 text-xs">{video.author}</p>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</div>

<script>
  import "@mux/mux-video";

  document.querySelectorAll<HTMLElement>(".video-card").forEach((card) => {
    const poster = card.querySelector<HTMLImageElement>(".video-poster");
    const videoEl = card.querySelector<HTMLElement>(".video-player");
    const overlay = card.querySelector<HTMLElement>(".video-overlay");

    if (!poster || !videoEl || !overlay) return;

    card.addEventListener("click", (e) => {
      // Don't intercept clicks on native video controls
      if ((e.target as HTMLElement).closest("mux-video")) return;

      if (!poster.classList.contains("hidden")) {
        // First click: set the playback-id and start playing
        const playbackId = videoEl.dataset.playbackId;
        if (playbackId) {
          videoEl.setAttribute("playback-id", playbackId);
        }
        poster.classList.add("hidden");
        overlay.classList.add("hidden");
        videoEl.classList.remove("hidden");
        // Defer play() until canplay to avoid AbortError:
        // setAttribute("playback-id") starts a new load, and calling play()
        // immediately races against that load, causing the browser to abort.
        videoEl.addEventListener("canplay", () => (videoEl as any).play(), {
          once: true,
        });
      } else {
        // Subsequent clicks on the overlay: toggle play/pause
        if ((videoEl as any).paused) {
          (videoEl as any).play();
        } else {
          (videoEl as any).pause();
        }
      }
    });

    videoEl.addEventListener("pause", () => {
      overlay.classList.remove("hidden");
    });

    videoEl.addEventListener("play", () => {
      overlay.classList.add("hidden");
    });
  });
</script>
