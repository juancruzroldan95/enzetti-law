---
import PlayerPlay from "../icons/PlayerPlay.astro";

const VIDEOS = [
  {
    id: 1,
    title: "Derechos laborales",
    poster: "/videos/poster-11.1.webp",
    duration: "0:22",
    author: "María - Secretaria",
    video_url: "/videos/11.1_small.mp4",
  },
  {
    id: 2,
    title: "Denunciar correctamente",
    poster: "/videos/poster-11.5.webp",
    duration: "0:38",
    author: "Juan - Abogado",
    video_url: "/videos/11.5_small.mp4",
  },
  {
    id: 3,
    title: "Iniciar un reclamo",
    poster: "/videos/poster-12.7.webp",
    duration: "0:25",
    author: "Laura - Coordinadora",
    video_url: "/videos/12.7_small.mp4",
  },
  {
    id: 4,
    title: "Accidente in itinere",
    poster: "/videos/poster-12.8.webp",
    duration: "0:25",
    author: "Ana - Asistente Legal",
    video_url: "/videos/12.8_small.mp4",
  },
];
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
  {/* Header */}
  <div class="text-center max-w-3xl mx-auto mb-16">
    <h2 class="text-sm font-bold text-accent uppercase tracking-wider mb-3">
      Nuestro Equipo
    </h2>
    <h3 class="text-4xl md:text-5xl font-bold text-primary mb-6">
      Conocé cómo trabajamos
    </h3>
    <p class="text-lg text-gray-600">
      Nuestro equipo te cuenta el proceso y compromiso que tenemos con cada caso
    </p>
  </div>

  {/* Videos Grid - Instagram style */}
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
    {
      VIDEOS.map((video) => (
        <div
          class="relative group cursor-pointer video-card"
          data-video-url={video.video_url}
        >
          {/* Video Container - Instagram format (9:16 ratio) */}
          <div class="relative aspect-[9/16] rounded-2xl overflow-hidden shadow-lg bg-gray-900">

            {/* Poster image — shown by default, no video bytes loaded */}
            <img
              src={video.poster}
              alt={video.title}
              class="video-poster w-full h-full object-cover"
              loading="lazy"
            />

            {/* Video element — src is empty until user clicks */}
            <video
              class="video-player w-full h-full object-cover absolute inset-0 hidden"
              playsinline
              controls
              disablepictureinpicture
              disableRemotePlayback
            />

            {/* Overlay — visible while poster is shown, hidden when video plays */}
            <div class="video-overlay absolute inset-0 transition-opacity duration-300">
              {/* Dark overlay */}
              <div class="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition-colors duration-300" />

              {/* Play button */}
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-16 h-16 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-xl text-accent text-2xl">
                  <PlayerPlay />
                </div>
              </div>

              {/* Duration badge */}
              <div class="absolute top-3 right-3 bg-black/70 backdrop-blur-sm text-white text-xs font-semibold px-2 py-1 rounded">
                {video.duration}
              </div>

              {/* Info overlay */}
              <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/90 to-transparent">
                <p class="text-white font-bold text-sm mb-1">{video.title}</p>
                <p class="text-white/80 text-xs">{video.author}</p>
              </div>
            </div>

          </div>
        </div>
      ))
    }
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>(".video-card").forEach((card) => {
    const poster = card.querySelector<HTMLImageElement>(".video-poster");
    const videoEl = card.querySelector<HTMLVideoElement>(".video-player");
    const overlay = card.querySelector<HTMLElement>(".video-overlay");
    const videoUrl = card.dataset.videoUrl;

    if (!poster || !videoEl || !overlay || !videoUrl) return;

    card.addEventListener("click", (e) => {
      // Don't intercept clicks on native video controls
      if ((e.target as HTMLElement).closest("video")) return;

      if (!poster.classList.contains("hidden")) {
        // First click: inject src and start playing
        videoEl.src = videoUrl;
        poster.classList.add("hidden");
        overlay.classList.add("hidden");
        videoEl.classList.remove("hidden");
        videoEl.play();
      } else {
        // Subsequent clicks on the overlay: toggle play/pause
        if (videoEl.paused) {
          videoEl.play();
        } else {
          videoEl.pause();
        }
      }
    });

    videoEl.addEventListener("pause", () => {
      overlay.classList.remove("hidden");
    });

    videoEl.addEventListener("play", () => {
      overlay.classList.add("hidden");
    });
  });
</script>
