---

---

<div
  class="relative overflow-hidden flex items-center justify-center min-h-[52vh]"
>
  {/* Background — deep primary with layered depth */}
  <div class="absolute inset-0 bg-primary" />

  {/* Subtle diagonal pattern */}
  <div class="absolute inset-0 texture-plus-light opacity-75" />

  {/* Crimson bloom — top-left */}
  <div
    class="absolute top-0 left-0 w-80 h-80 bg-accent/15 rounded-full blur-[80px] -translate-x-1/3 -translate-y-1/3"
  />
  {/* Indigo bloom — bottom-right */}
  <div
    class="absolute bottom-0 right-0 w-96 h-96 bg-blue-600/8 rounded-full blur-[80px] translate-x-1/4 translate-y-1/4"
  />

  {/* Gold rule — top */}
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent" />
  {/* Gold rule — bottom */}
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/20 to-transparent" />

  <div class="max-w-5xl mx-auto px-4 sm:px-8 relative z-10 text-center py-16">
    {/* Large decorative quote mark */}
    <div
      class="text-white/5 text-[10rem] leading-none font-serif absolute top-4 left-1/2 -translate-x-1/2 select-none pointer-events-none"
      style="font-family: var(--font-serif);"
      aria-hidden="true"
    >
      "
    </div>

    <h2
      class="text-3xl md:text-5xl lg:text-6xl font-bold text-white leading-tight tracking-tight min-h-[120px] md:min-h-[160px] flex flex-col justify-center items-center gap-4 relative z-10"
      style="font-family: var(--font-serif);"
    >
      <div class="typewriter-container inline-block relative">
        <span id="typewriter-text" class="whitespace-pre-wrap"></span><span
          id="cursor"
          class="inline-block w-0.5 h-9 md:h-14 bg-accent ml-1 align-middle animate-pulse"
        ></span>
      </div>
    </h2>

    <div class="sr-only">
      "Defender tus derechos es nuestra prioridad, obtener la Máxima
      Indemnización es nuestro compromiso."
    </div>

    {/* Attribution line */}
    <div class="mt-8 flex items-center justify-center gap-3 text-white/25 text-xs tracking-widest uppercase font-sans">
      <span class="w-8 h-px bg-accent/40" />
      <span>Estudio Jurídico Enzetti</span>
      <span class="w-8 h-px bg-accent/40" />
    </div>
  </div>
</div>

<script>
  import { animate, inView } from "motion";

  const text1 = "Defender tus derechos es nuestra prioridad, ";
  const text2 = "obtener la Máxima Indemnización ";
  const text3 = "es nuestro compromiso.";

  const textElement = document.getElementById("typewriter-text");
  const cursorElement = document.getElementById("cursor");

  const typeSpeed = 38;

  async function typeWriter(text: string, element: HTMLElement, speed = 38) {
    if (!element) return;
    for (const char of text) {
      if (!document.body.contains(element)) return;
      element.textContent += char;
      const randomSpeed = speed + Math.random() * 18 - 9;
      await new Promise((resolve) => setTimeout(resolve, randomSpeed));
    }
  }

  let hasRun = false;

  if (textElement && cursorElement) {
    inView(textElement, () => {
      if (hasRun) return;
      hasRun = true;

      const runSequence = async () => {
        textElement.innerHTML = "";
        await typeWriter(text1, textElement, typeSpeed);
        await new Promise((r) => setTimeout(r, 350));
        await typeWriter(text2, textElement, typeSpeed);

        const span = document.createElement("span");
        span.className = "relative inline-block px-1 text-white";
        span.textContent = "";
        textElement.appendChild(span);
        await typeWriter(text3, span, typeSpeed);

        if (cursorElement) cursorElement.style.display = "none";

        const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
        svg.setAttribute(
          "class",
          "absolute left-0 bottom-0 w-full h-4 sm:h-5 text-accent -z-10 translate-y-2",
        );
        svg.setAttribute("viewBox", "0 0 200 9");
        svg.setAttribute("preserveAspectRatio", "none");
        svg.style.overflow = "visible";

        const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
        path.setAttribute(
          "d",
          "M2.00025 6.99997C28.5269 3.52046 80.5986 1.34139 120.5 2.50005C150.932 3.38379 175.5 4.99999 198 7.50002",
        );
        path.setAttribute("fill", "none");
        path.setAttribute("stroke", "currentColor");
        path.setAttribute("stroke-width", "3");
        path.setAttribute("stroke-linecap", "round");
        path.setAttribute("stroke-dasharray", "1");
        path.setAttribute("pathLength", "1");
        path.style.opacity = "0.8";

        svg.appendChild(path);
        span.appendChild(svg);

        animate(path, { pathLength: [0, 1] }, { duration: 0.7, ease: "easeOut" });
      };

      runSequence();
    });
  }
</script>
