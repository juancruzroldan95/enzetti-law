---
import { Image } from "astro:assets";
import accidenteTrabajo from "../assets/images/accidente-de-trabajo.jpg";
import accidenteTransito from "../assets/images/accidente-de-transito.jpg";
import enfermedadesProfesionales from "../assets/images/enfermedades-profesionales.jpg";

const SERVICES = [
  {
    id: 1,
    title: "Accidentes de Trabajo",
    description:
      "Reclamamos la indemnización que merecés tras lesiones sufridas en el ámbito laboral. Te asistimos en cada etapa del proceso.",
    image: accidenteTrabajo,
    slug: "accidentes-de-trabajo",
  },
  {
    id: 2,
    title: "Enfermedades Profesionales",
    description:
      "Te ayudamos a obtener lo justo por dolencias como hernias, tendinitis u otras lesiones relacionadas al esfuerzo laboral.",
    image: enfermedadesProfesionales,
    slug: "enfermedades-profesionales",
  },
  {
    id: 3,
    title: "Accidentes de Tránsito",
    description:
      "Gestionamos tu indemnización por lesiones, daños materiales y perjuicios sufridos en cualquier accidente vial.",
    image: accidenteTransito,
    slug: "accidentes-de-transito",
  },
];
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
  {/* Header */}
  <div class="text-center max-w-3xl mx-auto mb-16">
    <h2
      class="text-sm font-bold text-accent uppercase tracking-wider mb-3"
      id="calculadora-de-indemnizacion"
    >
      Abogados Especialistas en ART
    </h2>
    <h3 class="text-4xl md:text-5xl font-bold text-primary mb-6">
      Calculadora de indemnización y Reclamos
    </h3>
    <p class="text-lg text-gray-600">
      Descubrí cuánto te corresponde por ART. Gestionamos tu <strong
        >indemnización por accidente de trabajo</strong
      > o enfermedad profesional para que cobres lo justo.
    </p>
  </div>

  {/* Services Grid */}
  <div class="grid md:grid-cols-3 gap-8">
    {
      SERVICES.map((service) => {
        return (
          <a
            href={`/${service.slug}`}
            class="group relative bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 overflow-hidden service-card block"
          >
            {/* Image */}
            <div class="relative h-56 overflow-hidden">
              <Image
                src={service.image}
                alt={service.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
            </div>

            {/* Content */}
            <div class="p-6 space-y-4">
              <h4 class="text-2xl font-bold text-primary group-hover:text-accent transition-colors duration-300">
                {service.title}
              </h4>
              <p class="text-gray-600 leading-relaxed">{service.description}</p>
              <span class="inline-flex items-center text-accent font-semibold transition-colors group/btn">
                Conocer más
                <span class="ml-2 group-hover:translate-x-1 transition-transform">
                  →
                </span>
              </span>
            </div>

            {/* Hover border effect */}
            <div class="absolute inset-0 border-2 border-transparent group-hover:border-accent/20 rounded-2xl transition-colors duration-300" />
          </a>
        );
      })
    }
  </div>
</div>
