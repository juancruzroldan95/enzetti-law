---
import { Image } from "astro:assets";
import accidenteTrabajo from "../assets/images/accidente-de-trabajo.jpg";
import accidenteTransito from "../assets/images/accidente-de-transito.jpg";
import enfermedadesProfesionales from "../assets/images/enfermedades-profesionales.jpg";

const SERVICES = [
  {
    id: 1,
    title: "Accidentes de Trabajo",
    description:
      "Reclamamos la indemnización que merecés tras lesiones sufridas en el ámbito laboral. Te asistimos en cada etapa del proceso.",
    image: accidenteTrabajo,
    slug: "accidentes-de-trabajo",
    number: "01",
  },
  {
    id: 2,
    title: "Enfermedades Profesionales",
    description:
      "Te ayudamos a obtener lo justo por dolencias como hernias, tendinitis u otras lesiones relacionadas al esfuerzo laboral.",
    image: enfermedadesProfesionales,
    slug: "enfermedades-profesionales",
    number: "02",
  },
  {
    id: 3,
    title: "Accidentes de Tránsito",
    description:
      "Gestionamos tu indemnización por lesiones, daños materiales y perjuicios sufridos en cualquier accidente vial.",
    image: accidenteTransito,
    slug: "accidentes-de-transito",
    number: "03",
  },
];
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
  {/* Header */}
  <div class="text-center max-w-3xl mx-auto mb-16">
    <div class="accent-rule mb-4">
      <span>Abogados Especialistas</span>
    </div>
    <h2
      class="text-5xl md:text-6xl font-bold text-primary mb-5 leading-tight"
      id="calculadora-de-indemnizacion"
    >
      Calculá tu indemnización
    </h2>
    <p class="text-base text-primary/60 leading-relaxed max-w-xl mx-auto">
      Descubrí cuánto te corresponde por ART. Gestionamos tu reclamo para que cobres
      la <strong class="text-primary/80">máxima indemnización posible</strong>.
    </p>
  </div>

  {/* Services Grid */}
  <div class="grid md:grid-cols-3 gap-6">
    {
      SERVICES.map((service) => {
        return (
          <a
            href={`/${service.slug}`}
            class="group relative bg-white rounded-2xl overflow-hidden service-card block border border-stone-100 hover:border-transparent transition-all duration-500 hover:shadow-2xl hover:shadow-primary/10 hover:-translate-y-1"
          >
            {/* Image */}
            <div class="relative h-52 overflow-hidden">
              <Image
                src={service.image}
                alt={service.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
              {/* Gradient overlay */}
              <div class="absolute inset-0 bg-gradient-to-t from-primary/70 via-primary/20 to-transparent" />

              {/* Service number — editorial treatment */}
              <div class="absolute top-4 left-4">
                <span class="text-white/30 font-bold text-5xl leading-none select-none" style="font-family: var(--font-serif);">
                  {service.number}
                </span>
              </div>

              {/* Accent bar at bottom of image */}
              <div class="absolute bottom-0 left-0 w-0 group-hover:w-full h-0.5 bg-accent transition-all duration-500" />
            </div>

            {/* Content */}
            <div class="p-6 space-y-3">
              <h3
                class="text-2xl font-bold text-primary group-hover:text-accent transition-colors duration-300"
                style="font-family: var(--font-serif);"
              >
                {service.title}
              </h3>
              <p class="text-sm text-primary/60 leading-relaxed">{service.description}</p>
              <div class="pt-2 flex items-center gap-2 text-accent font-semibold text-sm">
                <span>Conocer más</span>
                <span class="group-hover:translate-x-1.5 transition-transform duration-300">→</span>
              </div>
            </div>
          </a>
        );
      })
    }
  </div>
</div>
