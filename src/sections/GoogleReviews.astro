---
import StarFilled from "../icons/StarFilled.astro";
import { getGoogleReviews } from "../services/google";

const googleReviews = await getGoogleReviews();
---

{
  googleReviews && (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      {/* Header */}
      <div class="text-center max-w-3xl mx-auto mb-16">
        <div class="accent-rule mb-4">
          <span>Reseñas de Clientes</span>
        </div>
        <h2 class="text-5xl md:text-6xl font-bold text-primary mb-6">
          Lo que dicen nuestros clientes
        </h2>

        {/* Google rating badge — responsive, won't overflow on mobile */}
        <div class="inline-flex flex-wrap items-center justify-center gap-x-4 gap-y-2 bg-white border border-zinc-200 rounded-2xl px-5 py-3 shadow-sm mx-auto">
          <img
            src="https://upload.wikimedia.org/wikipedia/commons/2/2f/Google_2015_logo.svg"
            alt="Google"
            class="h-5 flex-shrink-0"
          />
          <div class="flex items-center gap-2">
            <span class="text-2xl font-bold text-primary leading-none">
              {googleReviews.rating}
            </span>
            <div class="flex text-yellow-400 gap-0.5">
              {Array.from({ length: 5 }).map(() => (
                <span><StarFilled /></span>
              ))}
            </div>
          </div>
          <div class="text-sm text-zinc-500 border-l border-zinc-200 pl-4 text-left flex-shrink-0">
            <span class="font-bold text-primary">{googleReviews.total_reviews}</span>
            {" "}reseñas
          </div>
        </div>
      </div>

      {/* Reviews Grid */}
      <div class="flex flex-wrap gap-6 justify-center">
        {googleReviews.reviews.map((review) => (
          <a
            href={review.author_url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full md:w-[calc(50%_-_12px)] lg:w-[calc(33.333%_-_16px)] bg-white border border-zinc-100 rounded-2xl p-6 hover:border-accent/30 hover:shadow-xl hover:shadow-primary/8 transition-all duration-300 group flex flex-col review-card relative"
            title="Ver reseña en Google Maps"
          >
            {/* External link icon */}
            <div class="absolute top-4 right-4 text-zinc-300 group-hover:text-accent transition-colors">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
            </div>

            {/* Stars */}
            <div class="flex mb-4 text-yellow-400 gap-0.5">
              {Array.from({ length: review.rating }).map(() => (
                <span><StarFilled /></span>
              ))}
            </div>

            {/* Review text */}
            <p class="text-zinc-600 text-sm leading-relaxed mb-6 flex-grow">
              "{review.text}"
            </p>

            {/* Author */}
            <div class="flex items-center gap-3 pt-4 border-t border-zinc-100">
              <img
                src={review.avatar}
                alt={review.author}
                class="w-10 h-10 rounded-full object-cover flex-shrink-0"
              />
              <div>
                <div class="font-semibold text-sm text-primary group-hover:text-accent transition-colors">
                  {review.author}
                </div>
                <div class="text-xs text-zinc-400">{review.date}</div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  )
}
