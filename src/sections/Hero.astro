---
import ArrowRight from "../icons/ArrowRight.astro";
import Shield from "../icons/Shield.astro";
import WhatsApp from "../icons/WhatsApp.astro";
import Check from "../icons/Check.astro";
import { VIDEOS, muxThumbnail } from "../consts/videos";

const heroVideo = VIDEOS[0];
---

{/* Warm parchment background with fine grain */}
<div class="absolute inset-0 -z-10 h-full w-full bg-background">
  {/* Subtle cross-hatch texture */}
  <div class="absolute inset-0 texture-crosshatch" />
  {/* Warm gradient overlay */}
  <div class="absolute inset-0 bg-gradient-to-br from-background via-background to-amber-50/40" />
  {/* Crimson glow top-right */}
  <div class="absolute top-0 right-0 w-[600px] h-[600px]" style="background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 5%, transparent) 0%, transparent 70%);" />
  {/* Navy glow bottom-left */}
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px]" style="background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 5%, transparent) 0%, transparent 70%);" />
</div>

<div
  class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 pt-10 lg:pb-24"
>
  <div class="grid lg:grid-cols-2 gap-12 items-center">
    {/* Left Content */}
    <div class="relative z-10 space-y-7 text-center lg:text-left">

      {/* Badge */}
      <div
        class="inline-flex items-center gap-2 border border-accent/30 bg-accent/5 text-accent px-4 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase opacity-0 translate-y-4 hero-badge"
      >
        <Shield class="w-3.5 h-3.5" />
        <span>Abogados Especialistas en ART</span>
      </div>

      {/* Heading with serif display font */}
      <h1
        class="text-5xl md:text-6xl lg:text-7xl font-bold text-primary leading-[1.05] opacity-0 translate-y-4 hero-title"
      >
        ¿Tuviste un <em class="text-accent not-italic">accidente</em> <span class="text-accent">de trabajo</span>?
      </h1>

      <div class="space-y-5">
        <p
          class="text-xl md:text-2xl font-semibold text-primary/80 opacity-0 translate-y-4 hero-desc-1 leading-snug"
        >
          Descubrí <strong class="text-primary">cuánto te corresponde</strong> por ART
        </p>

        <ul class="space-y-2.5 max-w-sm mx-auto lg:mx-0">
          {
            [
              "Accidentes de Trabajo",
              "Accidentes de Tránsito",
              "Enfermedades Profesionales",
            ].map((item) => (
              <li class="flex items-center justify-center lg:justify-start gap-3 text-base text-primary/70 opacity-0 translate-y-4 hero-list-item">
                <div class="w-5 h-5 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                  <Check class="w-3 h-3 text-accent" />
                </div>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>

      {/* CTAs */}
      <div
        class="flex flex-col sm:flex-row gap-3 pt-2 justify-center lg:justify-start"
      >
        <a
          href="https://wa.me/5491143711602"
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto opacity-0 translate-y-4 hero-btn-1"
        >
          <button
            class="w-full md:w-[310px] h-[60px] bg-green-500 hover:bg-green-600 text-white font-bold text-base px-6 rounded-xl shadow-lg shadow-green-500/20 hover:shadow-green-500/40 transition-all duration-300 hover:scale-[1.02] flex items-center justify-center gap-3 cursor-pointer group"
          >
            <WhatsApp
              class="w-5 h-5 group-hover:rotate-12 transition-transform duration-300"
            />
            Calculá tu indemnización
          </button>
        </a>
        <a
          href="#servicios"
          class="w-full sm:w-auto opacity-0 translate-y-4 hero-btn-2"
        >
          <button
            class="w-full md:w-[240px] h-[60px] border border-primary/30 bg-white/70 backdrop-blur-sm text-primary hover:bg-primary hover:text-white font-semibold text-base px-6 rounded-xl transition-all duration-300 hover:scale-[1.02] hover:shadow-lg flex items-center justify-center gap-2 cursor-pointer group"
          >
            Nuestros servicios
            <ArrowRight class="group-hover:translate-x-1 transition-transform" />
          </button>
        </a>
      </div>

      {/* Stats */}
      <div
        id="hero-stats"
        class="grid grid-cols-3 gap-4 pt-6 border-t border-primary/10"
      >
        {
          [
            { target: "30", suffix: "+", label: "Años de experiencia" },
            { target: "5.0", suffix: "", label: "Calificación Google" },
            { target: "320", suffix: "+", label: "Reseñas positivas" },
          ].map((stat, i) => (
            <div class={`opacity-0 translate-y-4 hero-stat text-center lg:text-left`}>
              <div class="text-3xl font-bold text-accent flex items-baseline gap-0.5 justify-center lg:justify-start" style="font-family: var(--font-serif);">
                <span class="counter-value" data-target={stat.target} data-float={stat.target.includes(".") ? "true" : "false"}>
                  {stat.target.includes(".") ? "0.0" : "0"}
                </span>
                {stat.suffix && <span>{stat.suffix}</span>}
              </div>
              <div class="text-xs text-primary/50 mt-0.5 font-medium tracking-wide">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>

    {/* Right Column — Video */}
    <div class="relative z-20 opacity-0 scale-95 hero-image mt-6 lg:mt-0">
      {/* Decorative frame */}
      <div class="absolute -inset-3 rounded-3xl border border-accent/10 -z-10"></div>
      <div class="absolute -inset-6 rounded-[2rem] bg-gradient-to-br from-accent/5 to-transparent -z-20"></div>

      <div
        id="video-container"
        class="aspect-square rounded-2xl overflow-hidden shadow-2xl shadow-primary/20 relative group cursor-pointer ring-1 ring-primary/10"
      >
        <img
          id="hero-poster"
          src={muxThumbnail(heroVideo.playbackId)}
          alt={`Video del equipo Estudio Enzetti — ${heroVideo.title}`}
          class="w-full h-full object-cover"
        />

        <mux-video
          id="hero-video"
          class="w-full h-full absolute inset-0 hidden"
          data-playback-id={heroVideo.playbackId}
          metadata-video-title={heroVideo.title}
          poster={muxThumbnail(heroVideo.playbackId)}
          loop
          playsinline
          controls
          disable-tracking
        ></mux-video>

        {/* Play overlay */}
        <div
          id="play-overlay"
          class="absolute inset-0 bg-gradient-to-t from-primary/50 via-transparent to-transparent group-hover:from-primary/60 transition-all duration-300 flex items-end justify-start p-6"
        >
          <div class="flex items-center gap-4">
            <div
              id="play-button"
              class="w-14 h-14 bg-white/95 rounded-full flex items-center justify-center shadow-lg shadow-primary/30 transform transition-all duration-300 scale-90 group-hover:scale-100"
            >
              <svg
                id="icon-play"
                xmlns="http://www.w3.org/2000/svg"
                class="w-6 h-6 text-primary ml-0.5"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M8 5v14l11-7z"></path>
              </svg>
            </div>
            <div class="text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <p class="text-sm font-semibold">{heroVideo.title}</p>
              <p class="text-xs text-white/70">Ver video</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import "@mux/mux-video";
  import { animate, stagger, inView } from "motion";

  animate(
    ".hero-badge",
    { opacity: [0, 1], y: [16, 0] },
    { duration: 0.5, delay: 0.2 },
  );

  animate(
    ".hero-title",
    { opacity: [0, 1], y: [24, 0] },
    { duration: 0.7, delay: 0.35 },
  );

  animate(
    ".hero-desc-1",
    { opacity: [0, 1], y: [16, 0] },
    { duration: 0.6, delay: 0.55 },
  );

  animate(
    ".hero-list-item",
    { opacity: [0, 1], y: [12, 0] },
    { delay: stagger(0.08, { startDelay: 0.75 }), duration: 0.45 },
  );

  animate(
    ".hero-btn-1",
    { opacity: [0, 1], y: [16, 0] },
    { type: "spring", delay: 1.05 },
  );

  animate(
    ".hero-btn-2",
    { opacity: [0, 1], y: [16, 0] },
    { type: "spring", delay: 1.2 },
  );

  animate(
    ".hero-stat",
    { opacity: [0, 1], y: [16, 0] },
    { delay: stagger(0.12, { startDelay: 1.35 }), duration: 0.45 },
  );

  animate(
    ".hero-image",
    { opacity: [0, 1], scale: [0.96, 1] },
    { duration: 1, delay: 0.4 },
  );

  // Stats counter
  // The hero-stat elements animate in starting at ~1.35s from page load.
  // On desktop the stats are in-viewport on load, so we need a delay to sync.
  // On mobile the user scrolls to the stats later — by then the delay has
  // already elapsed, so we clamp it to 0 to avoid a frozen-counter flash.
  const counterStats = document.querySelectorAll(".counter-value");
  const scriptStartTime = performance.now();

  inView("#hero-stats", () => {
    const elapsed = (performance.now() - scriptStartTime) / 1000;
    const delay = Math.max(0, 1.4 - elapsed);

    counterStats.forEach((counter) => {
      const targetStr = counter.getAttribute("data-target");
      const isFloat = counter.getAttribute("data-float") === "true";
      if (!targetStr) return;
      const target = parseFloat(targetStr);

      // @ts-expect-error - Motion overload
      animate(0, target, {
        duration: 1.6,
        delay,
        easing: "ease-out",
        onUpdate: (latest: number) => {
          counter.textContent = isFloat
            ? latest.toFixed(1)
            : Math.round(latest).toString();
        },
      });
    });
  });

  // Video player
  const heroVideoEl = document.getElementById("hero-video") as HTMLElement;
  const heroPoster = document.getElementById("hero-poster") as HTMLImageElement;
  const videoContainer = document.getElementById("video-container");
  const playOverlay = document.getElementById("play-overlay");

  if (heroVideoEl && heroPoster && videoContainer && playOverlay) {
    const patchInternalVideo = () => {
      const internal = heroVideoEl.shadowRoot?.querySelector("video");
      if (internal) {
        internal.style.width = "100%";
        internal.style.height = "100%";
        internal.style.objectFit = "cover";
        internal.style.objectPosition = "center center";
      }
    };

    videoContainer.addEventListener("click", () => {
      if (heroVideoEl.classList.contains("hidden")) {
        const playbackId = heroVideoEl.dataset.playbackId;
        if (playbackId) heroVideoEl.setAttribute("playback-id", playbackId);
        heroPoster.classList.add("hidden");
        playOverlay.classList.add("hidden");
        heroVideoEl.classList.remove("hidden");
        patchInternalVideo();
        heroVideoEl.addEventListener(
          "canplay",
          () => {
            patchInternalVideo();
            (heroVideoEl as any).play();
          },
          { once: true },
        );
      }
    });
  }
</script>
